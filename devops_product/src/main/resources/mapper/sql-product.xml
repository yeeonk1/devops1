<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="org.cloud.mapper.ProductMapper">
	<select id="productList" resultType="org.cloud.dto.ProductDTO">
		<![CDATA[
			SELECT 
				num, name, price, amount
			FROM
				product
			ORDER BY num DESC;		
		]]>
	</select>
	
	<insert id="insertProduct" parameterType="org.cloud.dto.ProductDTO">
		<![CDATA[
			INSERT INTO product
			(
				name, price, amount
			)
			VALUES
			(
				#{name}, #{price}, #{amount}
			)
		]]>
	</insert>
	
	<select id="productDetail" parameterType="int" resultType="org.cloud.dto.ProductDTO">
		<![CDATA[
			SELECT 
				num, name, price, amount
			FROM
				product
			WHERE num = #{num}	
		]]>
	</select>
	
	<update id="updateProduct" parameterType="org.cloud.dto.ProductDTO">
		<![CDATA[
			UPDATE
				product
			SET
				name = #{name},
				price = #{price},
				amount = #{amount}
			WHERE 
				num = #{num}		
		]]>
	</update>
	
	<delete id="deleteProduct" parameterType="int">
		<![CDATA[
			DELETE
			FROM
				product
			WHERE 
				num = #{num}	
		]]>
	</delete>
</mapper>  
  
  
  
  
  
  
  
  
  
  